{
  "model": {
    "name": "射覆占断师",
    "version": "2.0"
  },
  "api": {
    "endpoint": "/chat/completions",
    "method": "POST",
    "temperature": 0.7,
    "max_tokens": 2000,
    "timeout_ms": 30000
  },
  "prompt": {
    "system_prompt_file": "./prompt.json",
    "user_prompt_template": "请根据以下三组随机数进行射覆占断：第一数：{num1}，第二数：{num2}，第三数：{num3}。请严格按照JSON格式输出结果。"
  }
}